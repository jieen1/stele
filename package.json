{
  "name": "stele-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "test:conformance": "pnpm --filter @stele/conformance-tests test",
    "test:packed-adoption": "node scripts/verify-packed-adoption.mjs",
    "release:dry-run": "node scripts/publish-npm.mjs --dry-run",
    "release:publish": "node scripts/publish-npm.mjs",
    "typecheck": "pnpm --filter @stele/core build && pnpm --filter @stele/backend-python build && pnpm -r run typecheck",
    "lint": "pnpm -r run lint"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "tsup": "^8.0.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.0"
  }
}
