(metadata
  (stele-version "0.1")
  (project "effect-fixture-03-forbid-policy-violation"))

(effect-declarations
  (effect "db.read" (description "Reading from database"))
  (effect "db.write" (description "Writing to database"))
  (effect "http.outgoing" (description "Outgoing HTTP request")))

(effect-annotation
  (target "src/db.ts::findUser(*)")
  (annotates "db.read"))

(effect-policy NO_IO_IN_UI
  (description "UI components must be pure render functions.")
  (target-scope "src/components/**")
  (forbid "db.read" "db.write" "http.outgoing")
  (severity "error")
  (fix-hint "Move the `findUser` call out of `UserCard` into a route loader or server-side handler. If the rule is wrong (server-rendered component), propose a design update via `stele design propose --effect-policy NO_IO_IN_UI`. Do NOT edit the contract directly."))
