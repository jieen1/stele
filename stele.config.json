{
  "version": "0.1",
  "contractDir": "contract",
  "entry": "contract/main.stele",
  "generatedDir": "tests/contract",
  "checkerImplDir": "contract/checker_impls",
  "manifestPath": "contract/.manifest.json",
  "targetLanguage": "python",
  "testFramework": "pytest",
  "pathMode": "auto",
  "tsconfig": "tsconfig.base.json",
  "phaseLanguages": {
    "trace": "typescript",
    "type-state": "typescript",
    "effect": "typescript",
    "architecture": "typescript"
  },
  "effectStrictMode": false,
  "protected": [
    "contract/**/*.stele",
    "contract/checker_impls/**/*",
    "contract/design/**/*",
    "contract/generated/**/*",
    "contract/.baseline.json",
    "contract/.manifest.json",
    "tests/contract/**/*",
    "packages/claude-code-plugin/scripts/*.js",
    "packages/claude-code-plugin/hooks/hooks.json",
    "stele.config.json",
    ".stele/stop-state.json"
  ]
}
