{
  "name": "@stele/backend-python",
  "version": "0.1.0",
  "description": "Python pytest backend for translating Stele contracts into generated contract tests.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean && node -e \"import('fs').then(f=>{f.default.cpSync('src/runtime','dist/runtime',{recursive:true}); f.default.mkdirSync('dist/extractors',{recursive:true}); f.default.copyFileSync('src/extractors/python_call_graph_extractor.py','dist/extractors/python_call_graph_extractor.py');})\"",
    "prepack": "npm run build",
    "test": "vitest run --dir tests",
    "typecheck": "tsc --project tsconfig.json --noEmit --pretty false",
    "lint": "tsc --project tsconfig.json --noEmit --pretty false"
  },
  "dependencies": {
    "@stele/call-graph-core": "workspace:*",
    "@stele/core": "workspace:*",
    "@stele/effect-evaluator": "workspace:*"
  },
  "license": "MIT",
  "repository": "github:stelehq/stele",
  "homepage": "https://github.com/stelehq/stele",
  "bugs": {
    "url": "https://github.com/stelehq/stele/issues"
  }
}
