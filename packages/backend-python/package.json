{
  "name": "@stele/backend-python",
  "version": "0.1.0",
  "description": "Python backend for generating pytest-compatible Stele artifacts.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run --dir tests",
    "typecheck": "tsc --project tsconfig.json --noEmit --pretty false",
    "lint": "tsc --project tsconfig.json --noEmit --pretty false"
  },
  "dependencies": {
    "@stele/core": "workspace:*"
  }
}
