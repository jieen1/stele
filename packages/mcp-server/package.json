{
  "name": "@stele/mcp-server",
  "version": "0.1.0",
  "description": "MCP server for Stele contract-aware AI agent integration",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "stele-mcp": "dist/bin/mcp-server.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "~1.29.0",
    "@stele/agent-hooks": "workspace:*",
    "@stele/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^4.0.0"
  }
}
