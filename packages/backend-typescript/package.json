{
  "name": "@stele/backend-typescript",
  "version": "0.1.0",
  "description": "TypeScript backend for Stele v0.2 (Phase A: skeleton + basic operators).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && node -e \"import('fs').then(f=>f.default.cpSync('src/runtime','dist/runtime',{recursive:true}))\"",
    "prepack": "npm run build",
    "test": "vitest run --dir tests",
    "typecheck": "tsc --project tsconfig.json --noEmit --pretty false",
    "lint": "tsc --project tsconfig.json --noEmit --pretty false"
  },
  "dependencies": {
    "@stele/call-graph-core": "workspace:*",
    "@stele/core": "workspace:*",
    "@stele/effect-evaluator": "workspace:*",
    "@stele/type-state-evaluator": "workspace:*"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "license": "MIT",
  "repository": "github:stelehq/stele",
  "homepage": "https://github.com/stelehq/stele",
  "bugs": {
    "url": "https://github.com/stelehq/stele/issues"
  }
}
