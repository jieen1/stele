{
  "name": "@stele/type-state-evaluator",
  "version": "0.1.0",
  "description": "Type-state evaluator: turns TypeStateDeclaration[] + TypeStateBindingDeclaration[] + CallGraph + per-backend state-inference into Violation[].",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepack": "npm run build",
    "test": "vitest run --dir tests",
    "typecheck": "tsc --project tsconfig.json --noEmit --pretty false"
  },
  "dependencies": {
    "@stele/call-graph-core": "workspace:*",
    "@stele/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.7.3",
    "vitest": "^4.0.0",
    "tsup": "^8.3.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": "github:stelehq/stele",
  "homepage": "https://github.com/stelehq/stele",
  "bugs": {
    "url": "https://github.com/stelehq/stele/issues"
  }
}
