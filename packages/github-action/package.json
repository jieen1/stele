{
  "name": "@stele/github-action",
  "version": "0.1.0",
  "description": "GitHub Action that runs Stele contract checks on pull requests with annotations and a live-updating PR comment.",
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "dist",
    "action.yml",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "ncc build src/main.ts -o dist --license licenses.txt",
    "prepack": "npm run build",
    "test": "vitest run --dir __tests__",
    "typecheck": "tsc --project tsconfig.json --noEmit --pretty false",
    "lint": "tsc --project tsconfig.json --noEmit --pretty false"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@stele/core": "workspace:*"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.0"
  }
}
