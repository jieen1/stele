{
  "name": "@stele/cli",
  "version": "0.1.0",
  "description": "CLI entrypoint for Stele local development and CI workflows.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "stele": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run --dir tests",
    "typecheck": "tsc --project tsconfig.json --noEmit --pretty false",
    "lint": "tsc --project tsconfig.json --noEmit --pretty false"
  },
  "devDependencies": {
    "@types/glob-parent": "^5.1.0"
  },
  "dependencies": {
    "@stele/backend-python": "workspace:*",
    "@stele/core": "workspace:*",
    "commander": "^12.1.0",
    "glob-parent": "^6.0.2",
    "minimatch": "^9.0.5"
  }
}
