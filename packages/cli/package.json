{
  "name": "@stele/cli",
  "version": "0.1.0",
  "description": "Production CLI for initializing, generating, checking, and inspecting Stele contracts.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./backend-registry": {
      "types": "./dist/backend-registry.d.ts",
      "import": "./dist/backend-registry.js"
    }
  },
  "bin": {
    "stele": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts src/backend-registry.ts --format esm --dts --clean && node -e \"import('fs').then(f=>f.default.cpSync('templates','dist/templates',{recursive:true}))\"",
    "prepack": "npm run build",
    "test": "vitest run --dir tests",
    "typecheck": "tsc --project tsconfig.json --noEmit --pretty false",
    "lint": "tsc --project tsconfig.json --noEmit --pretty false"
  },
  "devDependencies": {
    "@types/glob-parent": "^5.1.0",
    "@types/js-yaml": "^4.0.9"
  },
  "dependencies": {
    "@stele/backend-go": "workspace:*",
    "@stele/backend-java": "workspace:*",
    "@stele/backend-python": "workspace:*",
    "@stele/backend-rust": "workspace:*",
    "@stele/backend-typescript": "workspace:*",
    "@stele/core": "workspace:*",
    "@stele/mcp-server": "workspace:*",
    "commander": "^12.1.0",
    "glob-parent": "^6.0.2",
    "js-yaml": "4.1.0",
    "minimatch": "^10.0.0"
  },
  "peerDependencies": {
    "@stele/agent-hooks": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@stele/agent-hooks": {
      "optional": true
    }
  },
  "license": "MIT",
  "repository": "github:stelehq/stele",
  "homepage": "https://github.com/stelehq/stele",
  "bugs": {
    "url": "https://github.com/stelehq/stele/issues"
  }
}
