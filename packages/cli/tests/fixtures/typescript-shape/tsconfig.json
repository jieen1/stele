{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "valid/**/*.ts",
    "invalid/**/*.ts",
    "protected/**/*.ts",
    "branded/**/*.ts",
    "branded-invalid/**/*.ts"
  ]
}
