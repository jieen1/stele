(metadata
  (stele-version "0.1")
  (project "type-state-fixture-04-multi-state-chain-ok"))

(type-state ORDER_LIFECYCLE
  (description "Draft → Submitted → Paid → Shipped chain is legitimate.")
  (target "src/order.ts::Order")
  (severity "error")
  (states Draft Submitted Paid Shipped Cancelled)
  (initial Draft)
  (terminal Cancelled Shipped)
  (transition (from Draft) (via submit) (to Submitted))
  (transition (from Submitted) (via pay) (to Paid))
  (transition (from Paid) (via ship) (to Shipped))
  (transition (from Draft Submitted) (via cancel) (to Cancelled))
  (allowed-ops Draft addItem submit cancel)
  (allowed-ops Submitted pay cancel)
  (allowed-ops Paid ship)
  (fix-hint "If a step in the chain is reported, restructure the calls around `Order.submit` / `Order.pay` / `Order.ship`. Use `stele design propose --type-state ORDER_LIFECYCLE` to revise the rule."))
