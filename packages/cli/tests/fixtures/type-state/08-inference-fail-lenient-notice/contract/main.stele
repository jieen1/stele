(metadata
  (stele-version "0.1")
  (project "type-state-fixture-08-inference-fail-lenient-notice"))

(type-state ORDER_LIFECYCLE
  (description "Same shape as 07 — but lenient mode demotes inference fails to notices.")
  (target "src/order.ts::Order")
  (severity "error")
  (states Draft Submitted Paid Cancelled)
  (initial Draft)
  (terminal Cancelled)
  (transition (from Draft) (via submit) (to Submitted))
  (transition (from Submitted) (via pay) (to Paid))
  (transition (from Draft Submitted) (via cancel) (to Cancelled))
  (allowed-ops Draft addItem submit cancel)
  (allowed-ops Submitted pay cancel)
  (fix-hint "Add a phantom annotation `Order<\"Submitted\">` to `processOrder` or add a `(type-state-binding)`. Use `stele design propose --type-state ORDER_LIFECYCLE` to revise the rule."))
