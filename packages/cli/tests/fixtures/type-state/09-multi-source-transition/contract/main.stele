(metadata
  (stele-version "0.1")
  (project "type-state-fixture-09-multi-source-transition"))

(type-state ORDER_LIFECYCLE
  (description "Cancel transitions out of either Draft or Submitted.")
  (target "src/order.ts::Order")
  (severity "error")
  (states Draft Submitted Paid Cancelled)
  (initial Draft)
  (terminal Cancelled)
  (transition (from Draft) (via submit) (to Submitted))
  (transition (from Submitted) (via pay) (to Paid))
  (transition (from Draft Submitted) (via cancel) (to Cancelled))
  (allowed-ops Draft addItem submit cancel)
  (allowed-ops Submitted pay cancel)
  (fix-hint "If reported, adjust the call order around `Order.cancel`. Use `stele design propose --type-state ORDER_LIFECYCLE` to revise the rule."))
