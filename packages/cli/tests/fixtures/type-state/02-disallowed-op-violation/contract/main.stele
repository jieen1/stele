(metadata
  (stele-version "0.1")
  (project "type-state-fixture-02-disallowed-op-violation"))

(type-state ORDER_LIFECYCLE
  (description "addItem is illegal once the order is Paid.")
  (target "src/order.ts::Order")
  (severity "error")
  (states Draft Submitted Paid Cancelled)
  (initial Draft)
  (terminal Cancelled)
  (transition (from Draft) (via submit) (to Submitted))
  (transition (from Submitted) (via pay) (to Paid))
  (transition (from Draft Submitted) (via cancel) (to Cancelled))
  (allowed-ops Draft addItem submit cancel)
  (allowed-ops Submitted pay cancel)
  (fix-hint "Move the `Order.addItem` call before `Order.pay`, or propose a design update via `stele design propose --type-state ORDER_LIFECYCLE`. Do NOT edit the contract directly."))
