(metadata
  (stele-version "0.1")
  (project "type-state-fixture-03-transition-ok"))

(type-state ORDER_LIFECYCLE
  (description "Legitimate submit then pay transition chain.")
  (target "src/order.ts::Order")
  (severity "error")
  (states Draft Submitted Paid Cancelled)
  (initial Draft)
  (terminal Cancelled)
  (transition (from Draft) (via submit) (to Submitted))
  (transition (from Submitted) (via pay) (to Paid))
  (transition (from Draft Submitted) (via cancel) (to Cancelled))
  (allowed-ops Draft addItem submit cancel)
  (allowed-ops Submitted pay cancel)
  (fix-hint "Adjust the call order around `Order.submit` if a violation is reported. Use `stele design propose --type-state ORDER_LIFECYCLE` to revise the rule."))
