  (project "type-state-fixture-07-inference-fail-strict-error"))

(type-state ORDER_LIFECYCLE
  (description "Untyped parameter without a binding — inference fails.")
  (target "src/order.ts::Order")
  (severity "error")
  (states Draft Submitted Paid Cancelled)
  (initial Draft)
  (terminal Cancelled)
  (transition (from Draft) (via submit) (to Submitted))
  (transition (from Submitted) (via pay) (to Paid))
  (transition (from Draft Submitted) (via cancel) (to Cancelled))
  (allowed-ops Draft addItem submit cancel)
  (allowed-ops Submitted pay cancel)
  (fix-hint "Add a phantom annotation `Order<\"Submitted\">` to the `processOrder` parameter, or add a `(type-state-binding)` declaration. Use `stele design propose --type-state ORDER_LIFECYCLE` to revise the rule."))
