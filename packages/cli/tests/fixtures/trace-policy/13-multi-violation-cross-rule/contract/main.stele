(metadata
  (stele-version "0.1")
  (project "trace-fixture-13-multi-violation-cross-rule"))

(trace-policy PAYMENT_PRECEDE
  (description "Stripe charges must be preceded by PermissionService.verify in the same body.")
  (target "**::Stripe::create(*)")
  (scope "src/order-service.ts::**")
  (must-be-preceded-by "**::PermissionService::verify(*)")
  (fix-hint "Insert `await PermissionService.verify(orderId)` before `Stripe.create(...)`.")
  (severity "error"))

(trace-policy PAYMENT_FOLLOW
  (description "Stripe charges must be followed by AuditLog.write in the same body.")
  (target "**::Stripe::create(*)")
  (scope "src/order-service.ts::**")
  (must-be-followed-by "**::AuditLog::write(*)")
  (fix-hint "Append `AuditLog.write(...)` after the `Stripe.create(...)` call.")
  (severity "error"))

(trace-policy PAYMENT_INDIRECT
  (description "OrderService.pay must not call Stripe.create directly — route via PaymentGateway.")
  (target "**::Stripe::create(*)")
  (scope "src/order-service.ts::**")
  (deny-direct "src/order-service.ts::**")
  (fix-hint "Insert a `PaymentGateway.charge(...)` indirection between the order service and `Stripe.create`.")
  (severity "error"))
