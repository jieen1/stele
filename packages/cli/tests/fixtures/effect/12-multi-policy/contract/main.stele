(metadata
  (stele-version "0.1")
  (project "effect-fixture-12-multi-policy"))

(effect-declarations
  (effect "db.read" (description "Reading from database"))
  (effect "db.write" (description "Writing to database"))
  (effect "http.outgoing" (description "Outgoing HTTP request"))
  (effect "time.now" (description "Reading current time")))

(effect-annotation
  (target "src/db.ts::findUser(*)")
  (annotates "db.read"))

(effect-annotation
  (target "src/http.ts::*")
  (annotates "http.outgoing"))

(effect-annotation
  (target "src/clock.ts::*")
  (annotates "time.now"))

(effect-policy NO_IO_IN_UI
  (description "UI components must be pure render functions.")
  (target-scope "src/components/**")
  (forbid "db.read" "db.write" "http.outgoing")
  (severity "error")
  (fix-hint "Move the `findUser` call out of `UserCard`. If the rule is wrong, propose a design update via `stele design propose --effect-policy NO_IO_IN_UI`. Do NOT edit the contract directly."))

(effect-policy PURE_LIB_ONLY
  (description "Pure library functions may read time but nothing else.")
  (target-scope "src/lib/pure/**")
  (allow-only "time.now")
  (severity "error")
  (fix-hint "Remove the `getJson` call from `formatRemote`. If the rule is wrong, propose a design update via `stele design propose --effect-policy PURE_LIB_ONLY`. Do NOT edit the contract directly."))
