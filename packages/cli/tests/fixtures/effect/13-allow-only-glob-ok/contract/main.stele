(metadata
  (stele-version "0.1")
  (project "effect-fixture-13-allow-only-glob-ok"))

(effect-declarations
  (effect "payment.charge" (description "Calling payment provider for charge"))
  (effect "payment.refund" (description "Calling payment provider for refund"))
  (effect "log.audit" (description "Writing audit log")))

(effect-annotation
  (target "src/payment.ts::*")
  (annotates "payment.charge" "payment.refund"))

(effect-annotation
  (target "src/audit.ts::*")
  (annotates "log.audit"))

(effect-policy PAYMENT_GATEWAY_ONLY_PAYMENT
  (description "Payment gateway functions may only do payment.* effects.")
  (target-scope "src/gateway/**")
  (allow-only "payment.*")
  (severity "error")
  (fix-hint "Keep `processCharge` payment-only — see `src/gateway/process.ts:1`. If the rule is wrong, propose a design update via `stele design propose --effect-policy PAYMENT_GATEWAY_ONLY_PAYMENT`. Do NOT edit the contract directly."))
