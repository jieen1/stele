(architecture "ddd-context-map"
  (lang typescript)
  (tsconfig "packages/cli/tsconfig.json")
  (description "Generated context map: cross-context dependencies must follow declared integration patterns.")

  (module cli-infrastructure
    (path "packages/cli/src/{events,config,utils,errors,version,last-report,backend-registry}/**"))
  (module core-internal
    (path "packages/core/src/{loader,normalizer,manifest,baseline}/**"))
  (module architecture-internal
    (path "packages/architecture-core/src/**"))
  (module backends-ts-internal
    (path "packages/backend-typescript/src/**"))
  (module backends-py-internal
    (path "packages/backend-python/src/**"))
  (module hooks-internal
    (path "packages/agent-hooks/src/handlers/**")
    (path "packages/agent-hooks/src/adapters/**")
  )
  (module mcp-internal
    (path "packages/mcp-server/src/{sessions/**,types.ts,session-state.ts}"))
  (module hooks-infrastructure
    (path "packages/agent-hooks/src/{install,util}/**"))
  (module mcp-infrastructure
    (path "packages/mcp-server/src/{bin/**,tools/**,server.ts,error-sanitizer.ts,stele-binary.ts}"))
  (module trace-evaluator-internal
    (path "packages/trace-evaluator/src/**"))
  (module type-state-evaluator-internal
    (path "packages/type-state-evaluator/src/**"))
  (module effect-evaluator-internal
    (path "packages/effect-evaluator/src/**"))
  (module type-driven-evaluator-internal
    (path "packages/type-driven-evaluator/src/**"))
  (module call-graph-core-internal
    (path "packages/call-graph-core/src/**"))

  (allow-dependency hooks-internal hooks-infrastructure)
  (allow-dependency hooks-infrastructure hooks-internal)
  (allow-dependency mcp-internal mcp-infrastructure)
  (allow-dependency mcp-infrastructure mcp-internal)
  (allow-dependency cli-infrastructure core-internal)
  (allow-dependency cli-infrastructure architecture-internal)
  (allow-dependency cli-infrastructure backends-ts-internal)
  (allow-dependency cli-infrastructure backends-py-internal)
  (allow-dependency cli-infrastructure hooks-internal)
  (allow-dependency cli-infrastructure mcp-internal)
  (allow-dependency backends-ts-internal core-internal)
  (allow-dependency backends-py-internal core-internal)
  (allow-dependency architecture-internal core-internal)
  (allow-dependency hooks-infrastructure core-internal)
  (allow-dependency mcp-infrastructure core-internal)
  (allow-dependency mcp-infrastructure hooks-internal)
  (allow-dependency cli-infrastructure trace-evaluator-internal)
  (allow-dependency cli-infrastructure type-state-evaluator-internal)
  (allow-dependency cli-infrastructure effect-evaluator-internal)
  (allow-dependency cli-infrastructure type-driven-evaluator-internal)
  (allow-dependency trace-evaluator-internal core-internal)
  (allow-dependency trace-evaluator-internal call-graph-core-internal)
  (allow-dependency type-state-evaluator-internal core-internal)
  (allow-dependency type-state-evaluator-internal call-graph-core-internal)
  (allow-dependency effect-evaluator-internal core-internal)
  (allow-dependency effect-evaluator-internal call-graph-core-internal)
  (allow-dependency backends-ts-internal call-graph-core-internal)
  (allow-dependency backends-ts-internal effect-evaluator-internal)
  (allow-dependency backends-ts-internal type-state-evaluator-internal)
  (allow-dependency call-graph-core-internal core-internal)

  (deny-cycles)
  (fix "Use the declared ACL module instead of importing the target context directly."))

(core-node "core-operator-registry-aggregate"
  (lang typescript)
  (role business-core-service)
  (target "packages/core/src/registry/operators.ts::OperatorRegistry")
  (description "Generated from design profile: OperatorRegistry aggregate must remain reviewable.")
  (rationale "OperatorRegistry protects core core invariants; complexity drift makes agent changes risky.")
  (metric sloc (ideal 400) (max 800))
  (metric public-method-count (ideal 8) (max 20))
  (metric max-cyclomatic (ideal 10) (max 25))
)

(core-node "core-invariant-validator-aggregate"
  (lang typescript)
  (role business-core-service)
  (target "packages/core/src/validator/structure-invariant.ts::validateInvariant")
  (description "Generated from design profile: InvariantValidator aggregate must remain reviewable.")
  (rationale "InvariantValidator protects core core invariants; complexity drift makes agent changes risky.")
  (metric sloc (ideal 150) (max 350))
  (metric public-method-count (ideal 4) (max 10))
)

