(branded-id "RuleId"
  (target "packages/core/src/util/branded-types.ts::RuleId")
  (base-type "string")
  (pattern "/^[a-z][a-z0-9_.]*$/")
)

(branded-id "ContractPath"
  (target "packages/core/src/util/branded-types.ts::ContractPath")
  (base-type "string")
  (pattern "/^[^/]+\\.stele$/")
)

(branded-id "Sha256"
  (target "packages/core/src/util/branded-types.ts::Sha256")
  (base-type "string")
  (pattern "/^[0-9a-f]{64}$/")
)

(branded-id "PackageName"
  (target "packages/core/src/util/branded-types.ts::PackageName")
  (base-type "string")
  (pattern "/^[a-z][a-z0-9-]*(-[a-z0-9]+)*$/")
)

(smart-ctor "RuleId"
  (constructor "parseRuleId")
  (deny-raw "true")
)

(smart-ctor "ContractPath"
  (constructor "parseContractPath")
  (deny-raw "true")
)

(smart-ctor "Sha256"
  (constructor "parseSha256")
  (deny-raw "true")
)