    "core_invariants": [
      {
        "id": "inv-core-purity",
        "description": "Core engine must remain pure - no filesystem, network, or clock dependencies outside loader/manifest layers",
        "evolvability": "never",
        "status": "enforced",
        "enforcement": {
          "kind": "external-tool",
          "external_tool_ref": "architecture.ddd-core"
        }
      },
      {
        "id": "inv-no-cli-domain-import",
        "description": "CLI commands layer must not import from design-domain or core directly - only through application layer",
        "evolvability": "never",
        "status": "enforced",
        "enforcement": {
          "kind": "external-tool",
          "external_tool_ref": "architecture.ddd-cli"
        }
      },
      {
        "id": "inv-no-infra-to-domain",
        "description": "Infrastructure layer must not import from domain-services or domain-primitives",
        "evolvability": "with-review",
        "status": "enforced",
        "enforcement": {
          "kind": "external-tool",
          "external_tool_ref": "architecture.ddd-core"
        }
      },
      {
        "id": "inv-deterministic-output",
        "description": "All generator output must be deterministic - same input produces identical output",
        "evolvability": "never",
        "status": "pending"
      },
      {
        "id": "inv-no-node-in-domain",
        "description": "Domain layers (domain-primitives, domain-services) must not import node: modules",
        "evolvability": "never",
        "status": "enforced",
        "enforcement": {
          "kind": "external-tool",
          "external_tool_ref": "architecture.ddd-core"
        }
      },
      {
        "id": "inv-no-direct-backend-import",
        "description": "CLI application layer must not import backend translators directly - use backend-registry adapter",
        "evolvability": "with-review",
        "status": "enforced",
        "enforcement": {
          "kind": "external-tool",
          "external_tool_ref": "architecture.ddd-cli"
        }
      },
      {
        "id": "inv-path-safety",
        "description": "All file paths must be resolved through path-safety helpers, never constructed from raw input",
        "evolvability": "never",
        "status": "enforced",
        "enforcement": {
          "kind": "stele-rule",
          "rule_ref": "path-safety-checker"
        }
      }
    ]
  },
  "type_driven": {
    "enabled": true,
    "branded_ids": {
      "mode": "hard",
      "declarations": [
        {
          "name": "RuleId",
          "base_type": "string",
          "invariant": "matches /^[a-z][a-z0-9_.]*$/"
        },
        {
          "name": "ContractPath",
          "base_type": "string",
          "invariant": "matches /^[^/]+\\.stele$/"
        },
        {
          "name": "Sha256",
          "base_type": "string",
          "invariant": "matches /^[0-9a-f]{64}$/"
        },
        {
          "name": "PackageName",
          "base_type": "string",
          "invariant": "matches /^[a-z][a-z0-9-]*(-[a-z0-9]+)*$/"
        }
      ]
    },
    "smart_constructors": {
      "mode": "hard",
      "value_objects": [
        {
          "name": "RuleId",
          "constructor": "parseRuleId(input: string): RuleId",
          "deny_raw": true
        },
        {
          "name": "ContractPath",
          "constructor": "parseContractPath(input: string): ContractPath",
          "deny_raw": true
        },
        {
          "name": "Sha256",
          "constructor": "parseSha256(input: string): Sha256",
          "deny_raw": true
        }
      ]
    },
    "type_state": {
      "mode": "hard"
    }
  },
  "toolchain_contracts": {
    "typescript_config": {
      "required_options": {
        "strict": true,
        "noImplicitAny": true,
        "noImplicitOverride": true,
        "noFallthroughCasesInSwitch": true,
        "moduleResolution": "Bundler",
        "target": "ES2022"
      },
      "tsconfig_path": "tsconfig.base.json"
    },
    "typescript_diagnostics": {
      "enabled": true,
      "command": "pnpm --filter @stele/cli run typecheck"
    },
    "eslint": {
      "enabled": true,
      "command": "npx eslint --format json .",
      "format": "json",
      "rules": [
        "@typescript-eslint/no-unused-vars",
        "@typescript-eslint/no-explicit-any"
      ],
      "warning_is_error": true
    }
  },
  "self_constraints": {
    "no_baseline": true
  }
}
