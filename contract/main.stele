; ============================================================================
; CLI command invariants
; ============================================================================

(invariant REQUIRED_COMMANDS_EXIST
  (severity error)
  (description "Critical CLI commands must exist: init, generate, check, lock.")
  (uses-checker required-commands-exist))

; ============================================================================
; Error code invariants
; ============================================================================

(invariant ERROR_CODE_FAMILIES_PRESENT
  (severity error)
  (description "Core error module must define SteleError class.")
  (uses-checker error-code-families-present))

; ============================================================================
; Determinism invariants
; ============================================================================

(invariant DETERMINISTIC_GENERATION
  (severity error)
  (description "Generated test files must contain no obvious nondeterminism markers (timestamps, UUIDs, epoch, random ids). This is a heuristic content scan; true byte-stability across runs is enforced separately by the SHA-256 manifest hash and the pure generator coordinator.")
  (uses-checker generation-deterministic))

; ============================================================================
; Path safety
; ============================================================================

(invariant PATH_NO_TRAVERSAL
  (severity error)
  (description "Generated file paths must not escape the output directory via traversal.")
  (uses-checker path-no-traversal))

; ============================================================================
; Phase B self-protection: evaluators, CI strict mode, fix-hint analysis branch
; ============================================================================

(checker all-evaluators-compile
  (description "Every Phase B evaluator package must build to dist/index.js + dist/index.d.ts."))

(checker strict-mode-default-in-ci
  (description "Stele's own CI workflow must not pass --lenient-* flags to stele check."))

(checker fix-hint-requires-analysis-branch
  (description "Every default fix-hint in evaluator source must force agents to analyze [A] code issue vs [B] contract issue before acting."))

(invariant ALL_EVALUATORS_COMPILE
  (severity error)
  (description "@stele/call-graph-core, @stele/trace-evaluator, @stele/type-state-evaluator, @stele/effect-evaluator, @stele/type-driven-evaluator must each have buildable TypeScript with dist/index.js and dist/index.d.ts present.")
  (uses-checker all-evaluators-compile))

(invariant STRICT_MODE_DEFAULT_IN_CI
  (severity error)
  (description "Self-protection: this repo's CI workflow must use Stele's default strict behavior. No --lenient-effects, --lenient-typestate, --lenient-callgraph, --lenient-trace flags in .github/workflows/.")
  (uses-checker strict-mode-default-in-ci))

(invariant FIX_HINT_REQUIRES_ANALYSIS_BRANCH
  (severity error)
  (description "Default fix-hint generators in trace/type-state/effect evaluators MUST contain the keywords 'code issue', 'contract issue', 'propose', '[A]', '[B]'. This prevents agents from auto-fixing stale rules; forces them to first decide whether to fix the code or propose a contract change.")
  (uses-checker fix-hint-requires-analysis-branch))

(checker default-protected-consistent
  (description "The three default-protected-patterns lists (in core, cli, claude-code-plugin) must agree."))

(invariant DEFAULT_PROTECTED_CONSISTENT
  (severity error)
  (description "Round 4 D-13: packages/core/src/config/defaults.ts (DEFAULT_PROTECTED_PATTERNS), packages/cli/src/config/defaults.ts (DEFAULT_CONFIG.protected), and packages/claude-code-plugin/scripts/pre-tool-protect.js (DEFAULT_PROTECTED) must declare byte-equal sets of protected patterns. A future fix that updates one and forgets the others silently drops defense-in-depth for some path category.")
  (uses-checker default-protected-consistent))

(checker esm-relative-imports-keep-js
  (description "Every relative `import … from \"./X\"` in TS source must end in `.js` for native-ESM resolution."))

(invariant ESM_RELATIVE_IMPORTS_KEEP_JS
  (severity error)
  (description "Round 4 E-02 / CLAUDE.md: TypeScript files use `.js` extensions in relative imports because the packages ship as native ESM and Node's resolver does not infer extensions. A future agent dropping the `.js` suffix would silently break consumers on the npm registry.")
  (uses-checker esm-relative-imports-keep-js))

(checker hook-entrypoints-fail-closed
  (description "Every permission-gate hook script must declare an outer try/catch + non-zero exit (or failClosed call)."))

(invariant HOOK_ENTRYPOINTS_FAIL_CLOSED
  (severity error)
  (description "Round 4 E-04 / CLAUDE.md: pre-tool-protect.js and stop-validate.js MUST fail closed on uncaught errors — i.e., catch and call process.exit(<non-zero>) or failClosed(). Observation / context hooks are intentionally fail-open and are NOT under this invariant.")
  (uses-checker hook-entrypoints-fail-closed))

(checker core-has-no-stele-deps
  (description "@stele/core source must not import from other @stele/* packages (except @stele/call-graph-core, which is a legitimate leaf dep)."))

(invariant CORE_HAS_NO_STELE_DEPS
  (severity error)
  (description "Round 4 E-08 / CLAUDE.md: @stele/core is the leaf of the dependency direction `core ← backend-* ← cli`. An agent that imports from @stele/cli or @stele/backend-* inside packages/core/src would silently invert the layering.")
  (uses-checker core-has-no-stele-deps))

(checker no-cjs-require-in-ts-source
  (description "TS source under packages/*/src must not use CJS require() (CLAUDE.md 'ESM only')."))

(invariant NO_CJS_REQUIRE_IN_TS_SOURCE
  (severity error)
  (description "Round 7 (Round 5 deferred dogfood #1) / CLAUDE.md: 'ESM only'. Round 4 E-02 enforces the `.js` import suffix; this complement refuses CJS require() in TS source. The single allowed site (packages/cli/src/version.ts) reads package.json via createRequire(import.meta.url) and is explicitly allow-listed.")
  (uses-checker no-cjs-require-in-ts-source))

(checker tsconfig-base-strict-mode
  (description "tsconfig.base.json compilerOptions.strict must be true and no per-option strict flag may be individually disabled."))

(invariant TSCONFIG_BASE_STRICT_MODE
  (severity error)
  (description "Round 7 (Round 5 deferred dogfood #2) / CLAUDE.md 'Strict TypeScript'. An agent silently flipping strict to false (or disabling noImplicitAny / strictNullChecks etc.) would weaken type safety across every package. This check locks strict mode at the base config.")
  (uses-checker tsconfig-base-strict-mode))

(checker no-backward-compat-shims
  (description "TS source must not contain backward-compat shim markers like `// removed:`, `// TODO(compat)`, `// for backwards compat`, `// legacy shim`."))

(invariant NO_BACKWARD_COMPAT_SHIMS
  (severity error)
  (description "Round 7 (Round 5 deferred dogfood #3) / CLAUDE.md 'Don't add backward-compat shims, dead-flag toggles, or `// removed:` markers. When you remove code, remove it.'")
  (uses-checker no-backward-compat-shims))

(checker core-engine-purity
  (description "@stele/core source must not call Date.now / Math.random / process.env / crypto.randomBytes / crypto.randomUUID (one documented Date.now allowlist entry in hash-manifest.ts)."))

(invariant CORE_ENGINE_PURITY
  (severity error)
  (description "Round 7 (Round 5 deferred dogfood #4) / CLAUDE.md 'Core engine is pure. Same input must produce the same output.' Nondeterminism sources (clock / random / env / crypto) inside @stele/core silently break the byte-stable manifest hash and the generator's determinism contract.")
  (uses-checker core-engine-purity))

(checker cli-io-through-path-utils
  (description "Every packages/cli/src/commands/*.ts file that calls a node:fs write function must reference at least one path-safety helper (resolve / join / validateOutputPath / collectProtectedPaths / etc.)."))

(invariant CLI_IO_THROUGH_PATH_UTILS
  (severity error)
  (description "Round 7 (Round 5 deferred dogfood #5) / CLAUDE.md 'Path safety is the hot path. Any new file IO in packages/cli or packages/claude-code-plugin/scripts must resolve through the existing path-safety helpers — never construct paths from raw user/agent input.'")
  (uses-checker cli-io-through-path-utils))

(checker no-bare-locale-compare
  (description "Every .ts source file under packages/*/src must use `stableStringCompare(left, right)` from @stele/core instead of `String.prototype.localeCompare`. localeCompare reads ICU/host locale and produces different orderings across machines, which leaks into manifest hashes and generated test output."))

(invariant NO_BARE_LOCALE_COMPARE
  (severity error)
  (description "Round 9 P-01 / CLAUDE.md 'Core engine is pure. Same input must produce the same output.' `.localeCompare(` is locale-dependent — LANG=de_DE sorts `ä` between `a` and `z`, LANG=sv_SE sorts it after `z`. That breaks generator byte-stability AND manifest hash stability across machines. Use `stableStringCompare` from @stele/core instead.")
  (uses-checker no-bare-locale-compare))

(checker bash-extractors-shared
  (description "Both packages/claude-code-plugin/scripts/pre-tool-protect.js and observation-hook.js must import the bash-write-target extractors from the shared packages/claude-code-plugin/scripts/bash-extractors.js module. Neither file may re-implement any canonical extractor function locally."))

(invariant BASH_EXTRACTORS_SHARED
  (severity error)
  (description "Round 13 L-05/P-04: the audit hook (observation-hook.js) and the deny gate (pre-tool-protect.js) must see the same set of bash write targets. Earlier rounds found observation-hook missing 8 bypass classes — git-checkout / interpreter -c / wrapper-flag peeling / ln / rsync / truncate / chmod / chown — that pre-tool-protect blocked, so the maintenance summary was blind to those vectors. Sharing a single extractor module prevents the drift permanently.")
  (uses-checker bash-extractors-shared))

; ============================================================================
; Phase 0 (self-dogfooding plan) — per-phase language config consistency
; ============================================================================

(checker phase-language-config-valid
  (description "stele.config.json `phaseLanguages` field must be an object with keys in {trace, type-state, effect, code-shape, architecture} and values in {typescript, python, go, rust, java}; absent / empty is also valid."))

(invariant PHASE_LANGUAGE_CONFIG_VALID
  (severity error)
  (description "Phase 0 (self-dogfooding plan): the per-phase language override field, when set, must be type-correct so that downstream check-stages dispatch deterministically.")
  (uses-checker phase-language-config-valid))

; ============================================================================
; Phase 1 (self-dogfooding plan) — branded-id call-site enforcement.
; Defense in depth for the type-driven evaluator: even when the TS
; toolchain is bypassed, `pytest tests/contract` still catches raw
; literal assignments to branded-typed fields.
; ============================================================================

(checker rule-id-uses-branded-type
  (description "Every TS source assignment to a `rule_id` field must go through `ruleId()` smart constructor — no raw string literals."))

(invariant RULE_ID_USES_BRANDED_TYPE
  (severity error)
  (description "Phase 1 self-dogfooding: RuleId branded type must be the only way to construct a rule identifier in TS source. Catches `rule_id: \"stele:foo\"` raw-string assignments that bypass the smart constructor.")
  (uses-checker rule-id-uses-branded-type))

(checker sha256-uses-branded-type
  (description "Every TS source assignment to a `sha256` / `transitive_hash` / `contract_hash` / `own_hash` field must go through one of the recognized Sha256 factories — no raw string literals."))

(invariant SHA256_USES_BRANDED_TYPE
  (severity error)
  (description "Phase 1 self-dogfooding: SHA-256 hash values must always be computed via the sha256 smart-constructor (or one of the hash helpers that route through it). Catches hand-typed hash literals that bypass the brand.")
  (uses-checker sha256-uses-branded-type))

(checker contract-path-uses-branded-type
  (description "Every TS source `entry` / `contractPath` field assigned a literal `.stele` path must go through `contractPath()` smart constructor."))

(invariant CONTRACT_PATH_USES_BRANDED_TYPE
  (severity error)
  (description "Phase 1 self-dogfooding: ContractPath branded type guards `entry` and `contractPath` fields holding `.stele` literals so the path-shape invariant cannot be bypassed by inlining a typo.")
  (uses-checker contract-path-uses-branded-type))

(checker command-name-uses-branded-type
  (description "Every `.command(...)` and `new Command(...)` call in TS CLI source must construct its first-argument name through `commandName()` or the local `cmdSpec()` helper."))

(invariant COMMAND_NAME_USES_BRANDED_TYPE
  (severity error)
  (description "Phase 1 self-dogfooding: CommandName branded type catches accidental rename or typo of CLI command names. Every `program.command(\"...\")` and `new Command(\"...\")` site must validate the name through the smart constructor.")
  (uses-checker command-name-uses-branded-type))

(checker package-name-uses-branded-type
  (description "Every TS source `packageName:` field assignment must go through `packageName()` smart constructor (imported as `toPackageName` where it collides with a local field)."))

(invariant PACKAGE_NAME_USES_BRANDED_TYPE
  (severity error)
  (description "Phase 1 self-dogfooding: PackageName branded type guards the REGISTERED_BACKENDS list (and any future packageName field) so a typo'd `@stele/<backend>` name is caught at validation time.")
  (uses-checker package-name-uses-branded-type))

; ============================================================================
; Phase 2 (self-dogfooding plan) — code-shape contracts.
; All declarations target Stele's own TypeScript / hook-script source via the
; Round 14 P1 TypeScript code-shape evaluator. Each (lang typescript) form is
; evaluated by `@stele/cli` in-process (no Python runtime), so these run on
; every `stele check` regardless of `targetLanguage`.
; ============================================================================

; --- §2.1 boundary contracts --------------------------------------------------
; Adapted from the phase document for the Round 14 P1 TypeScript analyzer
; semantics: the TS analyzer captures imports as the module specifier only
; (no `::name` candidate), and `deny-call` only matches MODULE-LEVEL calls
; (both Python and TS analyzers skip into function bodies for the file-level
; `calls` list). So we deny on the full module path and use `allow-target`
; to enumerate the legitimate fs-importing files. New code in @stele/core
; that needs `node:fs/promises` now requires an explicit contract update.

(boundary core-no-fs-write-from-non-manifest
  (lang typescript)
  (target "packages/core/src/**/*.ts")
  (deny-import "node:fs/promises")
  (deny-import "node:fs")
  (allow-target "packages/core/src/manifest/**")
  (allow-target "packages/core/src/loader/load-contract.ts")
  (allow-target "packages/core/src/generator/file-walk.ts")
  (allow-target "packages/core/src/baseline/io.ts"))

; CLI commands route file IO through path-safety helpers; the few bootstrap
; commands that legitimately call writeFileSync are allow-listed. Since
; module-level call detection skips function bodies, we also deny imports
; of node:fs/promises and node:fs from commands that don't already route
; through the path-utils layer (covered defense-in-depth by
; cli_io_through_path_utils).
(boundary cli-commands-no-direct-fs-write
  (lang typescript)
  (target "packages/cli/src/commands/**/*.ts")
  (deny-call "writeFileSync")
  (deny-call "appendFileSync")
  (allow-target "packages/cli/src/commands/init.ts")
  (allow-target "packages/cli/src/commands/design/**"))

; Closeout 6 — all CLI backend package access goes through backend-registry.ts.
; Stage implementations may depend on registry-level extractor selectors, but
; must not import backend packages directly.
(boundary backend-load-via-registry
  (lang typescript)
  (target "packages/cli/src/**/*.ts")
  (deny-import "@stele/backend-python")
  (deny-import "@stele/backend-typescript")
  (deny-import "@stele/backend-go")
  (deny-import "@stele/backend-rust")
  (deny-import "@stele/backend-java")
  (allow-target "packages/cli/src/backend-registry.ts"))

; --- incident-wedge design lock (Lock 1) -------------------------------------
; C1 (G1): @stele/core import purity. The EFFECT half (no network/process
; effect in core) is already locked by CORE_IS_PURE_OR_FS_READ. This boundary
; adds the IMPORT half: core must never import child_process, a git client, or
; the incident/propose wedge modules. deny-import is hand-maintained -- any
; newly adopted git/LLM client specifier MUST be added here. Dynamic
; import()/require() are caught by the effect-policy backstop, not this boundary.
(boundary core-no-incident-or-process-imports
  (lang typescript)
  (target "packages/core/src/**/*.ts")
  (deny-import "node:child_process")
  (deny-import "child_process")
  (deny-import "simple-git")
  (deny-import "isomorphic-git")
  (deny-import "@stele/incident")
  (deny-import "@stele/propose")
  (deny-import "@stele/cli"))

; C1b: the incident-wedge command logic (draft/teeth/approve) is new
; security-critical code that shells out (git worktrees) and writes approval
; records. It must never gain a network dependency — an exfiltration vector in
; the incident path would let a drafted "contract" phone home. deny-import is
; hand-maintained; add any new network client specifier here.
(boundary incident-no-network
  (lang typescript)
  (target "packages/cli/src/commands/incident/**/*.ts")
  (deny-import "node:http")
  (deny-import "node:https")
  (deny-import "node:net")
  (deny-import "node:tls")
  (deny-import "node:dgram")
  (deny-import "http")
  (deny-import "https")
  (deny-import "node-fetch")
  (deny-import "axios")
  (deny-import "undici"))

; C1c: the MCP server bridges an agent fleet to Stele and shells out to the
; stele binary. It is a prime exfiltration surface — it must never import a
; network client in its own source (the stdio transport is not a network
; import). Anti-exfil import boundary over the whole MCP source tree.
(boundary mcp-no-network
  (lang typescript)
  (target "packages/mcp-server/src/**/*.ts")
  (deny-import "node:http")
  (deny-import "node:https")
  (deny-import "node:net")
  (deny-import "node:tls")
  (deny-import "node:dgram")
  (deny-import "http")
  (deny-import "https")
  (deny-import "node-fetch")
  (deny-import "axios")
  (deny-import "undici"))

; C2 (G2) KEYSTONE: the probabilistic incident draft writes only to
; .stele/incident/ and teeth proofs to .stele/proofs/. Neither may EVER be
; hashed -- not via a protected glob, the protected manifest, or the canonical
; cache hash-manifest (contract/.cache/hash-manifest.json). Implemented by
; scratch_never_hashed in self_protection.py (fail-closed).
(checker scratch-never-hashed
  (description "Scratch dirs .stele/incident and .stele/proofs never enter the hash boundary."))

(invariant SCRATCH_NEVER_HASHED
  (severity error)
  (description "G2: incident/proof scratch is never hashed -- no protected glob, manifest key, or cache key resolves under .stele/incident or .stele/proofs.")
  (rationale "The incident wedge's LLM/probabilistic step must stay outside the deterministic hash boundary; hashing scratch would let nondeterministic drafts corrupt the manifest.")
  (uses-checker scratch-never-hashed))

; --- §2.2 class-shape contracts -----------------------------------------------
; The TS analyzer only recognises real `class` declarations (not `interface` or
; type aliases), so each class-shape targets a concrete class. The phase doc's
; `OperatorRegistry`/`Manifest`/`ViolationReport` types are interfaces or type
; aliases. Closeout 6 binds the manifest API surface through the public
; @stele/core barrel exports because the actual manifest engine spans
; manifest.ts and lifecycle.ts. It also binds the report API through
; createViolationReport's same-file return type alias. The actual report
; shape is a factory returning fields, not a builder object with lifecycle
; methods.
;
; Phase 6 self-dogfooding (2026-05-25): the operator-registry class-shape
; previously written here as `operator-registry-shape` is now emitted from
; the DDD design profile by the design generator — see
; `(class-shape core-operator-registry-aggregate-shape ...)` in
; `contract/generated/ddd-typedriven.stele`. Single source of truth lives
; in `contract/design/profile.yaml::aggregate_roots[operator-registry]`.

(class-shape cli-command-error-shape
  (lang typescript)
  (target "packages/cli/src/errors.ts::CliCommandError")
  (must-extend "Error")
  (must-have-field "exitCode"))

(class-shape manifest-engine-shape
  (lang typescript)
  (target "packages/core/src/index.ts::writeManifest")
  (must-have-method "buildContractManifest")
  (must-have-method "writeContractManifestObject")
  (must-have-method "writeManifest")
  (must-have-method "verifyManifest")
  (must-have-method "asLoaded")
  (must-have-method "buildLoadedManifestForPaths")
  (must-have-method "lockManifest")
  (must-have-method "verifyLockedManifest")
  (must-have-method "verifyManifestToVerified")
  (must-have-method "writeLockedManifest")
  (aggregate-members
    "buildContractManifest"
    "writeContractManifestObject"
    "writeManifest"
    "verifyManifest"
    "asLoaded"
    "buildLoadedManifestForPaths"
    "lockManifest"
    "verifyLockedManifest"
    "verifyManifestToVerified"
    "writeLockedManifest"))

(class-shape violation-report-shape
  (lang typescript)
  (target "packages/core/src/report/types.ts::createViolationReport")
  (must-have-field "schema_version")
  (must-have-field "rule_id")
  (must-have-field "tool")
  (must-have-field "command")
  (must-have-field "ok")
  (must-have-field "summary")
  (must-have-field "violations")
  (must-have-field "notices"))

; --- §2.3 function-shape contracts --------------------------------------------
; Hook scripts are .js but live in a TypeScript monorepo and are parsed
; adequately by ts.createSourceFile (ScriptKind.JS) — see
; isTypeScriptFilePath / scriptKindFor in packages/cli/src/code-shape/.

(function-shape hook-fail-closed-v2
  (lang typescript)
  (target "packages/claude-code-plugin/scripts/pre-tool-protect.js::main")
  (must-have-call "failClosed"))

(function-shape stop-validate-fail-closed
  (lang typescript)
  (target "packages/claude-code-plugin/scripts/stop-validate.js::main")
  (must-have-call "blockStop"))

(function-shape write-atomic-has-rename
  (lang typescript)
  (target "packages/core/src/manifest/hash-manifest.ts::writeAtomic")
  (must-have-call "rename"))

; --- §2.4 type-policy contracts -----------------------------------------------
(type-policy no-any-in-core
  (lang typescript)
  (target "packages/core/src/**/*.ts")
  (deny-type "any"))

(type-policy rule-id-fields-branded
  (lang typescript)
  (target "packages/core/src/**/*.ts")
  (owner-name-suffix "Violation" "Notice" "Report")
  (require-field-type "rule_id" "RuleId"))

; --- §2.5 file-policy contracts -----------------------------------------------
; Targets only the hook ENTRYPOINT scripts (not the shared helper modules
; `bash-extractors.js` / `path-utils.js` / `shell-utils.js` which are
; module-side ESM imports and do not need a shebang).

(file-policy hook-scripts-shebang
  (lang typescript)
  (target "packages/claude-code-plugin/scripts/{pre-tool-protect,stop-validate,observation-hook,lifecycle-context}.js")
  (must-contain "#!/usr/bin/env node"))

; --- §3 trace-policy contracts ------------------------------------------------
; Phase B trace stage runs against the TypeScript call graph extracted from this
; repo (phaseLanguages.trace = "typescript"). Trace-policy semantics — confirmed
; against @stele/trace-evaluator and docs/design/phase-b/02-trace-based-policy.md:
;   `target` = the destination function the policy protects (path endpoint).
;   `scope`  = which callers participate (default: whole project).
;   `must-transit` = at least one intermediate node on the path from caller to
;                    target must match.
;   `deny-direct`  = a direct edge from a caller in scope to a deny-direct node
;                    is a violation.
;   `exempt`       = caller nodes that bypass the policy.
;
; NodeIds are confirmed against the live extractor output (~9.3k nodes,
; ~41k edges). External-package functions appear as `extern:<package>::...`,
; not `node:<module>::...` — the phase doc's `node:fs/promises::*` form was
; rewritten to `extern:node-fs::*` after reading the call graph.

; 3.1 — All writeFile calls in @stele/core must transit through writeAtomic.
; writeAtomic itself is exempted (it IS the legitimate writer).
(trace-policy FS_WRITES_VIA_WRITE_ATOMIC
  (description "Every fs writeFile call inside @stele/core must transit through writeAtomic.")
  (severity "error")
  (target "extern:node-fs::writeFile(*)")
  (must-transit "packages/core/src/manifest/hash-manifest.ts::writeAtomic(2)")
  (scope "packages/core/src/**/*.ts")
  (exempt "packages/core/src/manifest/hash-manifest.ts::writeAtomic(2)" (reason "writeAtomic IS the atomic wrapper; the policy exists to force callers into it."))
  (fix-hint "[A] Route the write through `writeAtomic` in `packages/core/src/manifest/hash-manifest.ts`. [B] If the call site legitimately needs a non-atomic write, add an explicit exempt entry here."))

; 3.2 — In check.ts, prepareCheckContextWithContract must be preceded in the
; same caller body by a call to loadContract. The phase doc's literal
; (target "runCheck") (must-transit "loadContract") form cannot fire because
; the call graph has no in-scope callers of runCheck (Commander registers it
; via property assignment, which the extractor does not model as a call edge).
; This must-be-preceded-by form expresses the same intent at the body level:
; the only legitimate path into prepareCheckContextWithContract is to first
; load the contract.
(trace-policy CHECK_PREPARE_VIA_LOAD_CONTRACT
  (description "prepareCheckContextWithContract callers in check.ts must call loadContract first.")
  (severity "error")
  (target "packages/cli/src/commands/check.ts::prepareCheckContextWithContract(*)")
  (must-be-preceded-by "extern:stele-core::loadContract(*)")
  (scope "packages/cli/src/commands/check.ts")
  (fix-hint "[A] Call `loadContract(resolve(projectDir, config.entry))` before constructing the context in `packages/cli/src/commands/check.ts:161`. [B] If a different loader is needed, declare an extern-alias and route through it."))

; 3.3 — In generate.ts, every writeAtomic call must be preceded in the same
; caller body by a call to coordinateGeneration. Without the coordinator,
; backend output isn't validated against the contract before being written;
; this is the body-level expression of "generate must go through the
; coordinator before any generated file lands on disk".
(trace-policy GENERATE_VIA_COORDINATOR
  (description "runGenerate must call coordinateGeneration before any writeAtomic — backend output must transit the core coordinator.")
  (severity "error")
  (target "extern:stele-core::writeAtomic(*)")
  (must-be-preceded-by "extern:stele-core::coordinateGeneration(*)")
  (scope "packages/cli/src/commands/generate.ts")
  (fix-hint "[A] Call `coordinateGeneration(contract, backend, config)` before writing files in `packages/cli/src/commands/generate.ts:99`. [B] If the coordinator is broken, fix it — don't route around it."))

; 3.5 — In approve.ts, every writeFileSync must be preceded in the same caller
; body by a call to resolveApprovedBy. The human-identity gate is the security
; model for design approvals: skipping it lets an agent forge approval records
; that survive the manifest-protection layer.
(trace-policy APPROVE_VIA_RESOLVE_APPROVED_BY
  (description "runDesignApprove must call resolveApprovedBy before writing any approval record — the human-identity gate is the security model.")
  (severity "error")
  (target "extern:node-fs::writeFileSync(*)")
  (must-be-preceded-by "packages/cli/src/commands/design/approve.ts::resolveApprovedBy(0)")
  (scope "packages/cli/src/commands/design/approve.ts")
  (fix-hint "[A] Approve flow MUST gate through `resolveApprovedBy` in `packages/cli/src/commands/design/approve.ts:180` before any `writeFileSync`. [B] If you're replacing the identity gate, write a new policy first."))

; Closeout 6 — trace-policy evaluator must receive the extern-alias registry
; built from the contract before evaluation. This protects cross-language
; `extern:<logical-name>::...` scopes from silently falling back to package
; names.
(trace-policy EVALUATOR_VIA_EXTERN_REGISTRY
  (description "buildTraceStage must build the extern-alias registry before evaluating trace policies.")
  (severity "error")
  (target "extern:stele-trace-evaluator::evaluateTracePolicies(*)")
  (must-be-preceded-by "extern:stele-call-graph-core::buildExternAliasRegistry(*)")
  (scope "packages/cli/src/commands/check-stages-trace.ts")
  (fix-hint "[A] Keep `buildExternAliasRegistry(...)` before `evaluateTracePolicies(...)` in `buildTraceStage`. [B] If evaluation moves behind another boundary, add a contract that proves the same ordering there before refactoring."))

; ============================================================================
; Phase 4 — Effect-policy adoption.
;
; The effect alphabet is declared once here so every effect-annotation,
; effect-policy, and effect-suppression in this file resolves through a known
; name table. `pure` is intentionally NOT declared: per the effect-system spec
; (docs/design/phase-b/04-effect-system.md §四), a node with `effects: []` is
; pure by construction — adding a `pure` effect name would only create false
; violations on allow-only policies.
;
; Dotted effect names (`fs.read`, `fs.write`, `crypto.hash`) are string-quoted
; because the CDL identifier alphabet rejects `.` (Round 14 reviewer V-04).
; ============================================================================

(effect-declarations
  (effect "fs.read")
  (effect "fs.write")
  (effect time)
  (effect random)
  (effect env)
  (effect network)
  (effect "crypto.hash")
  (effect process)
  (effect child-process))

; ============================================================================
; §4.3 — Effect policies on Stele's own source.
;
; Closeout 1 (2026-05-25): the effect evaluator now gates the
; `effect.unresolved_call_blocks_evaluation` rule on per-policy
; `target-scope` membership at the caller site. Out-of-scope unresolved
; calls emit nothing (no policy cares); in-scope ones are unconditionally
; error-severity. Authors of nodes whose callees the static extractor
; genuinely cannot resolve (function-typed parameters, interface dispatch,
; dynamic `await import(...)`) declare the node's complete effect set via
; `@stele:effects ...` in source — that declaration is closed-world and
; suppresses the unresolved-call check for that node. The prior global
; strict-mode knob (which silenced everything indiscriminately) is gone.
; ============================================================================

(effect-policy CORE_IS_PURE_OR_FS_READ
  (description "@stele/core/src is the pure-ish layer. Allowed: fs.read (loadContract, baseline IO), fs.write (the manifest/baseline IO layer), crypto.hash (manifest hashing). Forbidden: time, random, env, network, process, child-process — those belong to the cli or backends, not core. Effect inference (not just @stele:effects annotations) now makes these visible, so an un-annotated network/child-process/process/time call in core is caught. The few audited process/time leaf reads in the IO layer are pinned via per-leaf (effect-suppression ...). NOTE: pinning fs.write itself to the audited writer leaves is a possible follow-up now that inference makes every fs.write visible — it requires forbidding fs.write here + suppressing each of the ~4 direct write/unlink leaves.")
  (severity "error")
  (target-scope "packages/core/src/**::*")
  (allow-only "fs.read" "fs.write" "crypto.hash"))

(effect-policy HOOK_NO_NETWORK
  (description "Hook scripts must not have network effects — a hook that contacts the internet is an exfiltration risk.")
  (severity "error")
  (target-scope "packages/claude-code-plugin/scripts/*.js::*")
  (forbid "network"))

(effect-policy GENERATOR_NO_NETWORK_OR_CHILD_PROCESS
  (description "stele generate must be self-contained — no network, no shelling out. Determinism requires that generation is hermetic.")
  (severity "error")
  (target-scope "packages/cli/src/commands/generate.ts::*" "packages/cli/src/design-generator/**::*")
  (forbid "network" "child-process"))

; ============================================================================
; §4.4 — Effect suppressions: 3 legitimate fs.write leaves in @stele/core.
; Each is the canonical atomic writer or a thin wrapper around it. Round 7
; CORE_ENGINE_PURITY already documented this lone exemption.
; ============================================================================

(effect-suppression
  (target "packages/core/src/manifest/hash-manifest.ts::writeAtomic(2)")
  (suppresses "fs.write" time random process)
  (severity "warning")
  (reason "Canonical atomic writer. Builds a unique temp-file name from Date.now() (time) + randomBytes(8) (random) + process.pid (process); the fs.write is the actual atomic rename. Lone Stele/core write exemption documented since Round 7; `process` added when effect inference surfaced the previously-invisible process.pid read."))

; Audited `process`/`time` leaf reads in core's IO layer, surfaced by effect
; inference (previously invisible to the annotation-only model). Each is a
; legitimate leaf in the loader/manifest/baseline/path layer; CORE_IS_PURE stays
; strict (fs.read/fs.write/crypto.hash) everywhere else and these are the only
; audited exceptions. Suppressing at the originating leaf stops propagation.
(effect-suppression
  (target "packages/core/src/loader/load-contract.ts::safeFilePath(1)")
  (suppresses process)
  (severity "warning")
  (reason "Reads process.cwd() to render a contract path relative for diagnostics. Read-only environment access in the loader's path layer; no mutation."))

(effect-suppression
  (target "packages/core/src/manifest/manifest.ts::safeFilePath(1)")
  (suppresses process)
  (severity "warning")
  (reason "Reads process.cwd() to render a protected-file path relative for diagnostics. Read-only environment access; no mutation."))

(effect-suppression
  (target "packages/core/src/util/path-utils.ts::isPathWithin(2)")
  (suppresses process)
  (severity "warning")
  (reason "Reads process.platform to select case-insensitive path comparison on win32. Read-only environment access required for correct cross-platform path containment."))

(effect-suppression
  (target "packages/core/src/manifest/manifest.ts::buildContractManifest(3)")
  (suppresses time)
  (severity "warning")
  (reason "Reads the clock for the manifest's `generated_at` metadata field. The timestamp is NOT part of the verification hash (file hashes + contract_hash drive `stele check`), so it does not affect determinism of verification or generated test source."))

(effect-suppression
  (target "packages/core/src/baseline/types.ts::createViolationBaseline(1)")
  (suppresses time)
  (severity "warning")
  (reason "Reads the clock for the baseline's `generated_at` metadata field. Metadata only; not part of any verification hash."))

; ============================================================================
; §5 — Type-state lifecycles (self-dogfooding Phase 5).
;
; The phantom-type implementation lives in the per-lifecycle source file
; cited by each (target ...) line. Primary enforcement is at TypeScript
; compile time via the brand discriminator (V-05 state-keyed StateBrand);
; companion *.test-d.ts files under each package's tests/ directory
; exercise the discriminator and MUST NOT regress.
;
; The (type-state ...) form below feeds the @stele/type-state-evaluator
; which walks the call graph for `receiver.method(...)` calls on the
; target type. Free-function transitions are documented for human
; readers; the type-state evaluator silently matches zero callers until
; production call sites are routed through method-style transitions
; (deferred follow-up work, not blocking).
; ============================================================================

(type-state CALLGRAPH_LIFECYCLE
  (description "Phase B evaluators (trace / type-state / effect) must only consume a CallGraph that is Built or Cached. Calling an evaluator on a graph still Building is undefined behaviour — edges and unresolvedCalls may be incomplete.")
  (target "packages/call-graph-core/src/lifecycle.ts::TypedCallGraph")
  (severity "error")
  (states Empty Building Built Cached)
  (initial Empty)
  (terminal Cached)
  (transition (from Empty) (via startBuilding) (to Building))
  (transition (from Building) (via finalizeCallGraph) (to Built))
  (transition (from Built) (via cacheCallGraph) (to Cached))
  (allowed-ops Empty startBuilding)
  (allowed-ops Building finalizeCallGraph)
  (allowed-ops Built cacheCallGraph)
  (fix-hint "Route the graph through `emptyCallGraph` → `startBuilding` → `finalizeCallGraph` (→ `cacheCallGraph`) in `packages/call-graph-core/src/lifecycle.ts`. Evaluators must accept `TypedCallGraph<\"Built\">` or `TypedCallGraph<\"Cached\">` only. If the lifecycle is wrong, propose an update via `stele design propose --type-state CALLGRAPH_LIFECYCLE`."))

(type-state DESIGN_PROFILE_LIFECYCLE
  (description "A DesignProfile starts Raw (just parsed from YAML), advances to Validated after validateProfile accepts it, and reaches Hashed once its SHA-256 has been computed. Generators must only consume Hashed profiles — feeding a Raw or Validated profile bypasses the integrity gate.")
  (target "packages/cli/src/design-profile/lifecycle.ts::TypedDesignProfile")
  (severity "error")
  (states Raw Validated Hashed)
  (initial Raw)
  (terminal Hashed)
  (transition (from Raw) (via markProfileValidated) (to Validated))
  (transition (from Validated) (via hashValidatedProfile) (to Hashed))
  (allowed-ops Raw markProfileValidated)
  (allowed-ops Validated hashValidatedProfile)
  (fix-hint "Route the profile through `asRawProfile` → `markProfileValidated` → `hashValidatedProfile` in `packages/cli/src/design-profile/lifecycle.ts`. Generators must accept a `TypedDesignProfile<\"Hashed\">` only (e.g. `generateFromProfile` in `packages/cli/src/design-generator/ddd.ts`); read `.profile` off a `HashedDesignProfile` to obtain it. If the lifecycle is wrong, propose an update via `stele design propose --type-state DESIGN_PROFILE_LIFECYCLE`."))

(type-state APPROVAL_LIFECYCLE
  (description "An Approval record cannot be written to disk before the human-identity gate has run. Lifecycle: Drafting (created from raw payload) → IdentityChecked (resolveApprovedBy passed) → Signed (writeFileSync persisted). The on-disk path must only ever see a Signed approval.")
  (target "packages/cli/src/commands/design/approval-lifecycle.ts::Approval")
  (severity "error")
  (states Drafting IdentityChecked Signed)
  (initial Drafting)
  (terminal Signed)
  (transition (from Drafting) (via attachApprovedBy) (to IdentityChecked))
  (transition (from IdentityChecked) (via signApproval) (to Signed))
  (allowed-ops Drafting attachApprovedBy)
  (allowed-ops IdentityChecked signApproval)
  (fix-hint "Route the approval through `draftApproval(...)` → `attachApprovedBy(...)` → `signApproval(...)` in `packages/cli/src/commands/design/approval-lifecycle.ts`; the persist site must only accept `Approval<\"Signed\">`. If the lifecycle itself is wrong, propose an update via `stele design propose --type-state APPROVAL_LIFECYCLE` — do NOT edit the contract directly."))

(type-state MANIFEST_LIFECYCLE
  (description "Stele's ContractManifest is born Unloaded, becomes Loaded once parsed from disk, Locked once written via writeAtomic, and Verified once the on-disk SHA-256 set has been re-validated. Skipping a step is a violation of the lifecycle.")
  (target "packages/core/src/manifest/lifecycle.ts::Manifest")
  (severity "error")
  (states Unloaded Loaded Locked Verified)
  (initial Unloaded)
  (terminal Verified)
  (transition (from Unloaded) (via asLoaded) (to Loaded))
  (transition (from Loaded) (via lockManifest) (to Locked))
  (transition (from Locked) (via verifyLockedManifest) (to Verified))
  (allowed-ops Loaded asLoaded lockManifest)
  (allowed-ops Locked verifyLockedManifest)
  (fix-hint "Route the manifest through `asLoaded()` then `lockManifest()` then `verifyLockedManifest()` from `packages/core/src/manifest/lifecycle.ts`; skipping a transition is what trips this rule. If the lifecycle itself is wrong, propose an update via `stele design propose --type-state MANIFEST_LIFECYCLE` — do NOT edit the contract directly."))

(type-state INCIDENT_LIFECYCLE
  (description "An incident draft cannot reach the atomic apply→generate→lock sink before the teeth proof has been gated AND bound to this exact draft. Lifecycle: Drafted (validated draft + teeth gate passed) → TeethProven (enforceTeethGate accepted: TEETH_PROVEN or an explicit teeth-unavailable reason) → Bound (enforceTeethBinding confirmed the proof attests to THIS draft's parentSha/fixSha/test bytes). The apply/generate/lock sink must only ever see a Bound draft.")
  (target "packages/cli/src/commands/incident/incident-lifecycle.ts::ProvenDraft")
  (severity "error")
  (states Drafted TeethProven Bound)
  (initial Drafted)
  (terminal Bound)
  (transition (from Drafted) (via markTeethProven) (to TeethProven))
  (transition (from TeethProven) (via bindTeethProof) (to Bound))
  (allowed-ops Drafted markTeethProven)
  (allowed-ops TeethProven bindTeethProof)
  (fix-hint "Route the draft through `draftProvenDraft(...)` → `markTeethProven(...)` (only after `enforceTeethGate` accepts) → `bindTeethProof(...)` (only after `enforceTeethBinding` accepts) in `packages/cli/src/commands/incident/incident-lifecycle.ts`; the apply→generate→lock sink must only accept `ProvenDraft<\"Bound\">`. If the lifecycle itself is wrong, propose an update via `stele design propose --type-state INCIDENT_LIFECYCLE` — do NOT edit the contract directly."))


; ============================================================================
; Lock 1 -- Stop-hook scope + CLI exit-code surface (incident-wedge design lock)
; ============================================================================

; C3: the Stop hook (stop-validate.js) runs ONLY Stele-owned bounded stages --
; `stele check` + `pytest tests/contract`. It must NEVER reintroduce a
; full-project test-suite runner or the STELE_CONFORMANCE_ALLOW_SKIP escape
; hatch removed in Phase 1. Implemented by stop_hook_no_full_suite_runner
; (comment-aware, fail-closed) in self_protection.py.
(checker stop-hook-no-full-suite-runner
  (description "The Stop hook never runs a full project test suite -- only stele check + pytest tests/contract."))

(invariant STOP_HOOK_NO_FULL_SUITE_RUNNER
  (severity error)
  (description "stop-validate.js runs only `stele check` and `pytest tests/contract`; no pnpm/npm/yarn test, vitest, jest, or STELE_CONFORMANCE_ALLOW_SKIP may reappear.")
  (rationale "The Stop gate must stay bounded and preventive; an unbounded full-suite runner is paid on every Stop and belongs in CI, not the hook. The skip env-var was an escape hatch that defeats the gate.")
  (uses-checker stop-hook-no-full-suite-runner))

; C4a: the ExitCode const in packages/cli/src/errors.ts must define EXACTLY 8
; integer-literal members. Complements exit-codes-valid (values/names) by
; capping the COUNT, rejecting an additive 9th code. Fail-closed on read/parse.
(checker cli-exit-code-count-exact
  (description "The ExitCode const object defines exactly 8 integer-literal members -- no additive 9th code."))

(invariant CLI_EXIT_CODE_COUNT_EXACT
  (severity error)
  (description "packages/cli/src/errors.ts ExitCode must contain exactly 8 integer-literal members {0,1,2,3,4,5,6,99}.")
  (rationale "CLI exit codes are part of the user contract; silently adding a 9th code widens the contract surface unobserved.")
  (uses-checker cli-exit-code-count-exact))

; C4b: no CLI source under packages/cli/src may call process.exit(N) or assign
; process.exitCode = N with an integer literal outside the contracted set
; {0,1,2,3,4,5,6,99}. Complements exit-codes-valid (DEFINITION) by pinning
; call-site USAGE. Symbolic forms (ExitCode.X, variables) pass. Scans whole-file
; over *.ts/*.mts/*.cts/*.tsx; fail-closed on IO.
(checker cli-no-raw-exit-codes
  (description "No CLI call site exits with an integer literal outside the 8 contracted exit values."))

(invariant CLI_NO_RAW_EXIT_CODES
  (severity error)
  (description "process.exit(N) / process.exitCode = N in packages/cli/src must use only the contracted exit values {0,1,2,3,4,5,6,99}.")
  (rationale "An off-contract exit literal at a call site silently introduces an undocumented exit code even when the exit-code definition is intact.")
  (uses-checker cli-no-raw-exit-codes))

(import "generated/ddd-typedriven.stele")
