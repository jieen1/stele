  (description "No source file shall contain hardcoded API keys or credentials.")
  (uses-checker no-secrets-in-source))

(invariant PROTECTED_PATTERN_SAFE
  (severity error)
  (description "Default protected patterns must not escape project root via traversal or absolute paths.")
