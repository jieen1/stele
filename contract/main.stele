(metadata
  (stele-version "0.1")
  (project "stele-self"))

; ============================================================================
; Checker declarations — each maps to a Python function in checker_impls/
; ============================================================================

(checker backend-registries
  (description "Verify backend registry contains all 5 supported languages."))

(checker backend-contains-python
  (description "Python backend must be present."))

(checker backend-contains-typescript
  (description "TypeScript backend must be present."))

(checker backend-contains-go
  (description "Go backend must be present."))

(checker backend-contains-rust
  (description "Rust backend must be present."))

(checker backend-contains-java
  (description "Java backend must be present."))

(checker all-backends-compile
  (description "Every registered backend's TypeScript source must produce a valid dist/ build (verified via dist/index.js + dist/index.d.ts presence)."))

(checker config-schema-valid
  (description "stele.config.json must contain all required fields."))

(checker manifest-version-stable
  (description "Manifest format version must not change without a version bump."))

(checker exit-codes-valid
  (description "CLI exit codes must match spec: 8 codes (0/1/2/3/4/5/6/99), all with correct values."))

(checker cdl-no-single-quotes
  (description "No .stele file shall contain single-quoted strings."))

(checker cdl-utf8-valid
  (description "All .stele files must be valid UTF-8."))

(checker versions-pinned-together
  (description "All packages must release at the same version."))

(checker no-secrets-in-source
  (description "No source file shall contain hardcoded secrets."))

(checker generation-deterministic
  (description "Generated output must be byte-stable."))

(checker path-no-traversal
  (description "Generated paths must not escape the output directory."))

; --- New checkers ---

(checker operator-count-stable
  (description "Operator registry must have >= 50 operators."))

(checker operator-spec-consistent
  (description "Every operator spec must have all required fields."))

(checker manifest-hash-algorithm
  (description "Manifest must use SHA-256 hashing."))

(checker structural-types-stable
  (description "The 9 structural types must all be present."))

(checker hooks-fail-closed
  (description "Security hooks must exit non-zero on error."))

(checker hooks-registration-complete
  (description "All hook scripts referenced in hooks.json must exist."))

(checker required-commands-exist
  (description "Critical CLI commands must exist: init, generate, check, lock."))

(checker config-manifest-path-safe
  (description "manifestPath must enforce 2-segment paths."))

(checker error-code-families-present
  (description "Core error module must have SteleError class."))

(checker cli-exit-code-enum-complete
  (description "ExitCode enum must define all 8 codes with subclasses."))

(checker protected-pattern-safe
  (description "Protected patterns must not escape project root."))

(checker inline-version-sync
  (description "Inline version strings must match package.json."))

; ============================================================================
; Backend registry invariants
; ============================================================================

(invariant BACKEND_REGISTRY_COUNT
  (severity error)
  (description "The backend registry must include all 5 supported languages.")
  (uses-checker backend-registries))

(invariant BACKEND_REGISTRY_HAS_PYTHON
  (severity error)
  (description "Python backend must be present — it is the primary target.")
  (uses-checker backend-contains-python))

(invariant BACKEND_REGISTRY_HAS_TYPESCRIPT
  (severity error)
  (description "TypeScript backend must be present.")
  (uses-checker backend-contains-typescript))

(invariant BACKEND_REGISTRY_HAS_GO
  (severity error)
  (description "Go backend must be present.")
  (uses-checker backend-contains-go))

(invariant BACKEND_REGISTRY_HAS_RUST
  (severity error)
  (description "Rust backend must be present.")
  (uses-checker backend-contains-rust))

(invariant BACKEND_REGISTRY_HAS_JAVA
  (severity error)
  (description "Java backend must be present.")
  (uses-checker backend-contains-java))

(invariant ALL_BACKENDS_COMPILE
  (severity error)
  (description "Every registered backend package must have buildable TypeScript — dist/index.js and dist/index.d.ts must exist after pnpm build.")
  (uses-checker all-backends-compile))

; ============================================================================
; Manifest / config invariants
; ============================================================================

(invariant CONFIG_SCHEMA_VALID
  (severity error)
  (description "stele.config.json must contain all required fields.")
  (uses-checker config-schema-valid))

(invariant MANIFEST_VERSION_STABLE
  (severity error)
  (description "The manifest format version must not change without a matching config bump — verified against both stele.config.json and the committed HEAD copy of contract/.manifest.json (Round 7 M-13).")
  (uses-checker manifest-version-stable))

(invariant MANIFEST_HASH_ALGORITHM
  (severity error)
  (description "Manifest hashing must use SHA-256 — changing to a weaker algorithm undermines tamper detection.")
  (uses-checker manifest-hash-algorithm))

(invariant CONFIG_MANIFEST_PATH_SAFE
  (severity error)
  (description "manifestPath must enforce 2-segment paths to keep manifest paths project-relative.")
  (uses-checker config-manifest-path-safe))

; ============================================================================
; Exit code invariants
; ============================================================================

(invariant EXIT_CODES_MATCH_SPEC
  (severity error)
  (description "CLI exit codes: ALL 8 codes must be defined with correct values (SUCCESS=0, USER_ERROR=1, CONTRACT_FAIL=2, TAMPER_DETECTED=3, GENERATION_FAIL=4, CONFIG_ERROR=5, SCORE_BELOW_THRESHOLD=6, INTERNAL_ERROR=99).")
  (uses-checker exit-codes-valid))

(invariant CLI_EXIT_CODE_ENUM_COMPLETE
  (severity error)
  (description "ExitCode enum must define SUCCESS, USER_ERROR, CONTRACT_FAIL, TAMPER_DETECTED, GENERATION_FAIL, CONFIG_ERROR, SCORE_BELOW_THRESHOLD, INTERNAL_ERROR with subclasses.")
  (uses-checker cli-exit-code-enum-complete))

; ============================================================================
; CDL grammar invariants
; ============================================================================

(invariant CDL_NO_SINGLE_QUOTES
  (severity warning)
  (description "All .stele contract files must use double-quoted strings only.")
  (uses-checker cdl-no-single-quotes))

(invariant CDL_UTF8_VALID
  (severity error)
  (description "All .stele files must be valid UTF-8 encoded.")
  (uses-checker cdl-utf8-valid))

; ============================================================================
; Version consistency
; ============================================================================

(invariant VERSIONS_PINNED_TOGETHER
  (severity warning)
  (description "All packages must release at the same version.")
  (uses-checker versions-pinned-together))

(invariant INLINE_VERSION_SYNC
  (severity warning)
  (description "Inline version strings in source must match package.json versions.")
  (uses-checker inline-version-sync))

; ============================================================================
; Operator registry invariants
; ============================================================================

(invariant OPERATOR_COUNT_STABLE
  (severity error)
  (description "The operator registry must maintain >= 50 operators — a drop indicates accidental deletion.")
  (uses-checker operator-count-stable))

(invariant OPERATOR_SPEC_CONSISTENT
  (severity error)
  (description "Every operator spec must have name, parameters, returnType, and description fields.")
  (uses-checker operator-spec-consistent))

; ============================================================================
; Type system invariants
; ============================================================================

(invariant STRUCTURAL_TYPES_STABLE
  (severity error)
  (description "The 9 structural types (Number, String, Boolean, Path, Collection, Predicate, TimeRange, Symbol, Unknown) must be present.")
  (uses-checker structural-types-stable))

; ============================================================================
; Security invariants
; ============================================================================

(invariant NO_HARDCODED_SECRETS
  (severity error)
  (description "No source file shall contain hardcoded API keys or credentials.")
  (uses-checker no-secrets-in-source))

(invariant PROTECTED_PATTERN_SAFE
  (severity error)
  (description "Default protected patterns must not escape project root via traversal or absolute paths.")
  (uses-checker protected-pattern-safe))

; ============================================================================
; Hook security invariants
; ============================================================================

(invariant HOOKS_FAIL_CLOSED
  (severity error)
  (description "Security-critical hooks must fail closed (exit non-zero on error).")
  (uses-checker hooks-fail-closed))

(invariant HOOKS_REGISTRATION_COMPLETE
  (severity error)
  (description "All hook scripts referenced in hooks.json must exist on disk.")
  (uses-checker hooks-registration-complete))

; ============================================================================
; CLI command invariants
; ============================================================================

(invariant REQUIRED_COMMANDS_EXIST
  (severity error)
  (description "Critical CLI commands must exist: init, generate, check, lock.")
  (uses-checker required-commands-exist))

; ============================================================================
; Error code invariants
; ============================================================================

(invariant ERROR_CODE_FAMILIES_PRESENT
  (severity error)
  (description "Core error module must define SteleError class.")
  (uses-checker error-code-families-present))

; ============================================================================
; Determinism invariants
; ============================================================================

(invariant DETERMINISTIC_GENERATION
  (severity error)
  (description "Generated test output must be byte-stable across runs.")
  (uses-checker generation-deterministic))

; ============================================================================
; Path safety
; ============================================================================

(invariant PATH_NO_TRAVERSAL
  (severity error)
  (description "Generated file paths must not escape the output directory via traversal.")
  (uses-checker path-no-traversal))

; ============================================================================
; Phase B self-protection: evaluators, CI strict mode, fix-hint analysis branch
; ============================================================================

(checker all-evaluators-compile
  (description "Every Phase B evaluator package must build to dist/index.js + dist/index.d.ts."))

(checker strict-mode-default-in-ci
  (description "Stele's own CI workflow must not pass --lenient-* flags to stele check."))

(checker fix-hint-requires-analysis-branch
  (description "Every default fix-hint in evaluator source must force agents to analyze [A] code issue vs [B] contract issue before acting."))

(invariant ALL_EVALUATORS_COMPILE
  (severity error)
  (description "@stele/call-graph-core, @stele/trace-evaluator, @stele/type-state-evaluator, @stele/effect-evaluator, @stele/type-driven-evaluator must each have buildable TypeScript with dist/index.js and dist/index.d.ts present.")
  (uses-checker all-evaluators-compile))

(invariant STRICT_MODE_DEFAULT_IN_CI
  (severity error)
  (description "Self-protection: this repo's CI workflow must use Stele's default strict behavior. No --lenient-effects, --lenient-typestate, --lenient-callgraph, --lenient-trace flags in .github/workflows/.")
  (uses-checker strict-mode-default-in-ci))

(invariant FIX_HINT_REQUIRES_ANALYSIS_BRANCH
  (severity error)
  (description "Default fix-hint generators in trace/type-state/effect evaluators MUST contain the keywords 'code issue', 'contract issue', 'propose', '[A]', '[B]'. This prevents agents from auto-fixing stale rules; forces them to first decide whether to fix the code or propose a contract change.")
  (uses-checker fix-hint-requires-analysis-branch))

(checker default-protected-consistent
  (description "The three default-protected-patterns lists (in core, cli, claude-code-plugin) must agree."))

(invariant DEFAULT_PROTECTED_CONSISTENT
  (severity error)
  (description "Round 4 D-13: packages/core/src/config/defaults.ts (DEFAULT_PROTECTED_PATTERNS), packages/cli/src/config/defaults.ts (DEFAULT_CONFIG.protected), and packages/claude-code-plugin/scripts/pre-tool-protect.js (DEFAULT_PROTECTED) must declare byte-equal sets of protected patterns. A future fix that updates one and forgets the others silently drops defense-in-depth for some path category.")
  (uses-checker default-protected-consistent))

(checker esm-relative-imports-keep-js
  (description "Every relative `import … from \"./X\"` in TS source must end in `.js` for native-ESM resolution."))

(invariant ESM_RELATIVE_IMPORTS_KEEP_JS
  (severity error)
  (description "Round 4 E-02 / CLAUDE.md: TypeScript files use `.js` extensions in relative imports because the packages ship as native ESM and Node's resolver does not infer extensions. A future agent dropping the `.js` suffix would silently break consumers on the npm registry.")
  (uses-checker esm-relative-imports-keep-js))

(checker hook-entrypoints-fail-closed
  (description "Every permission-gate hook script must declare an outer try/catch + non-zero exit (or failClosed call)."))

(invariant HOOK_ENTRYPOINTS_FAIL_CLOSED
  (severity error)
  (description "Round 4 E-04 / CLAUDE.md: pre-tool-protect.js and stop-validate.js MUST fail closed on uncaught errors — i.e., catch and call process.exit(<non-zero>) or failClosed(). Observation / context hooks are intentionally fail-open and are NOT under this invariant.")
  (uses-checker hook-entrypoints-fail-closed))

(checker core-has-no-stele-deps
  (description "@stele/core source must not import from other @stele/* packages (except @stele/call-graph-core, which is a legitimate leaf dep)."))

(invariant CORE_HAS_NO_STELE_DEPS
  (severity error)
  (description "Round 4 E-08 / CLAUDE.md: @stele/core is the leaf of the dependency direction `core ← backend-* ← cli`. An agent that imports from @stele/cli or @stele/backend-* inside packages/core/src would silently invert the layering.")
  (uses-checker core-has-no-stele-deps))

(checker no-cjs-require-in-ts-source
  (description "TS source under packages/*/src must not use CJS require() (CLAUDE.md 'ESM only')."))

(invariant NO_CJS_REQUIRE_IN_TS_SOURCE
  (severity error)
  (description "Round 7 (Round 5 deferred dogfood #1) / CLAUDE.md: 'ESM only'. Round 4 E-02 enforces the `.js` import suffix; this complement refuses CJS require() in TS source. The single allowed site (packages/cli/src/version.ts) reads package.json via createRequire(import.meta.url) and is explicitly allow-listed.")
  (uses-checker no-cjs-require-in-ts-source))

(checker tsconfig-base-strict-mode
  (description "tsconfig.base.json compilerOptions.strict must be true and no per-option strict flag may be individually disabled."))

(invariant TSCONFIG_BASE_STRICT_MODE
  (severity error)
  (description "Round 7 (Round 5 deferred dogfood #2) / CLAUDE.md 'Strict TypeScript'. An agent silently flipping strict to false (or disabling noImplicitAny / strictNullChecks etc.) would weaken type safety across every package. This check locks strict mode at the base config.")
  (uses-checker tsconfig-base-strict-mode))

(checker no-backward-compat-shims
  (description "TS source must not contain backward-compat shim markers like `// removed:`, `// TODO(compat)`, `// for backwards compat`, `// legacy shim`."))

(invariant NO_BACKWARD_COMPAT_SHIMS
  (severity error)
  (description "Round 7 (Round 5 deferred dogfood #3) / CLAUDE.md 'Don't add backward-compat shims, dead-flag toggles, or `// removed:` markers. When you remove code, remove it.'")
  (uses-checker no-backward-compat-shims))

(checker core-engine-purity
  (description "@stele/core source must not call Date.now / Math.random / process.env / crypto.randomBytes / crypto.randomUUID (one documented Date.now allowlist entry in hash-manifest.ts)."))

(invariant CORE_ENGINE_PURITY
  (severity error)
  (description "Round 7 (Round 5 deferred dogfood #4) / CLAUDE.md 'Core engine is pure. Same input must produce the same output.' Nondeterminism sources (clock / random / env / crypto) inside @stele/core silently break the byte-stable manifest hash and the generator's determinism contract.")
  (uses-checker core-engine-purity))

(checker cli-io-through-path-utils
  (description "Every packages/cli/src/commands/*.ts file that calls a node:fs write function must reference at least one path-safety helper (resolve / join / validateOutputPath / collectProtectedPaths / etc.)."))

(invariant CLI_IO_THROUGH_PATH_UTILS
  (severity error)
  (description "Round 7 (Round 5 deferred dogfood #5) / CLAUDE.md 'Path safety is the hot path. Any new file IO in packages/cli or packages/claude-code-plugin/scripts must resolve through the existing path-safety helpers — never construct paths from raw user/agent input.'")
  (uses-checker cli-io-through-path-utils))

(import "generated/ddd-typedriven.stele")
